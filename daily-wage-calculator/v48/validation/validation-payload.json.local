      "integration": "Employee Master",
      "type": "data_flow",
      "description": "Daily Wage Calculator depends on Employee Master for work week configuration and departure dates. Configuration changes in daily wage settings are not clearly reflected in dependent modules like EOS Eligibility."
    }
