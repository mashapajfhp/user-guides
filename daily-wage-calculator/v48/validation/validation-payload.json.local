  "what_to_do": [
    {
      "task_id": "WTD-001",
      "task": "Configure Daily Wage Calculator Settings",
      "persona": "HR Admin | Super Admin",
      "cluster_id": "CLU-001",
      "steps": [
        "Navigate to Settings from the main dashboard",
        "Select Payroll from the settings menu",
        "Choose Daily Wage Calculation option",
        "Select calculation base: calendar days (30), working days (e.g., 22), or custom days",
        "Choose salary components to include in daily wage calculations",
        "Review configuration rules (weekends and public holidays exclusion options)",
        "Save and apply calculation settings"
      ],
      "expected_outcome": "Daily Wage Calculator is configured with the appropriate calculation base and salary components. The system is ready to apply these settings to all future wage calculations, including salary proration and leave encashment.",
      "rules_and_constraints": [
        "Calculation can be based on calendar days, working days, or custom days",
        "Weekends and public holidays can be excluded from calculations",
        "Most UAE and KSA companies use 30 custom days to align with local labor law",
        "Selected salary components will be factored into all daily wage calculations",
        "Calculation varies depending on month length (e.g., 31 days in January, 28 days in February)"
      ],
      "edge_cases": [
        "February has 28 days (29 in leap years), which affects daily wage calculations differently than 30-day months",
        "Months with 31 days will produce different daily rates than 30-day months if using calendar days",
        "Custom day configurations must align with local labor law requirements for the company's jurisdiction"
      ],
      "source_articles": [
        {
          "article_id": "14243704039185",
          "title": "Introduction to daily wage calculator",
          "url": "https://bayzathelp.zendesk.com/hc/en-gb/articles/14243704039185-Introduction-to-daily-wage-calculator"
        }
      ],
      "prd_refs": [],
      "_source": "article"
    },
    {
      "task_id": "WTD-002",
      "task": "Calculate and Process Daily Pay Deductions for Unpaid Leave",
      "persona": "HR Admin | People Manager | Finance Manager",
      "cluster_id": "CLU-002",
      "steps": [
        "Receive unpaid leave request from employee or manager",
        "Review and approve the unpaid leave request",
        "Determine the applicable leave policy (calendar days or working days)",
        "Calculate total working days for the leave period",
        "Subtract public holidays from the working days count",
        "Calculate daily pay rate by dividing total salary by number of actual working days",
        "Generate corresponding payroll deduction entry",
        "Verify deduction is reflected in payroll system"
      ],
      "expected_outcome": "Unpaid leave is processed with accurate daily pay deductions calculated and automatically reflected in the employee's payroll. The deduction amount correctly accounts for working days and public holidays based on the configured calculation method.",
      "rules_and_constraints": [
        "Daily pay is calculated by dividing total salary by number of actual working days",
        "Can use calendar days (30 days) or working days (e.g., 22 days) based on configuration",
        "Public holidays must be deducted from working days when calculating daily pay",
        "Deductions are automatically generated and reflected in payroll system",
        "Calculation method must match the Daily Wage Calculator configuration"
      ],
      "edge_cases": [
        "Public holidays falling within the unpaid leave period must be subtracted from the working days calculation",
        "Months with varying day counts (28, 30, or 31 days) affect the daily pay rate calculation",
        "Unpaid leave spanning multiple months may require separate calculations if the calculation base changes between months"
      ],
      "source_articles": [
        {
          "article_id": "14154746403601",
          "title": "How is daily pay calculated",
          "url": "https://bayzathelp.zendesk.com/hc/en-gb/articles/14154746403601-How-is-daily-pay-calculated"
        }
      ],
      "prd_refs": [],
      "_source": "article"
    }
  ],
  "what_to_watch_out_for": [
    {
      "issue_id": "WOF-001",
      "theme": "EOS and Leave Encashment Calculation Limitations",
      "cluster_id": "CLU-003",
      "limitation": "The platform cannot dynamically adjust End of Service (EOS) and leave encashment calculations for employees with mid-month departures and unpaid leave periods. The system rigidly calculates EOS using full monthly salary without considering actual days worked or payment received. Additionally, configuration changes in daily wage calculation are not immediately or clearly reflected in the EOS Eligibility section, creating confusion about whether settings have been successfully applied. Leave accrual defaults to monthly accrual that does not prorate for partial month departures.",
      "impact": "high",
      "affected_personas": [
        "HR Admin",
        "Finance Manager"
      ],
      "by_design": false,
      "design_rationale": null,
      "documented_workaround": null,
      "ticket_count": 3,
      "journey_stages": [
        "Setup",
        "Day-to-day Usage",
        "Reporting"
      ],
      "categories": [
        "calculation_bug",
        "ux_issue",
        "configuration_problem"
      ],
      "jira_refs": [
        "TSSD-3939",
        "TSSD-4033",
        "TSSD-4742"
      ],
      "status": "Backlog"
    },
    {
      "issue_id": "WOF-002",
      "theme": "Lack of Configurable Salary Proration Methods",
      "cluster_id": "CLU-004",
      "limitation": "The platform lacks granular salary proration configuration and applies a single rigid proration approach across all employees. Users cannot customize calculation methods between calendar days, working days, or group-specific approaches. The system cannot dynamically adjust salaries proportionally when employees work more or fewer than the standard 26 working days, and different employee groups cannot have different proration calculation methods.",
      "impact": "high",
      "affected_personas": [
        "HR Admin",
        "Finance Manager"
      ],
      "by_design": false,
      "design_rationale": null,
      "documented_workaround": null,
      "ticket_count": 3,
      "journey_stages": [
        "Setup",
        "Day-to-day Usage"
      ],
      "categories": [
        "feature_gap",
        "configuration_problem"
      ],
      "jira_refs": [
        "TSSD-4303",
        "TSSD-4882",
        "TSSD-4905"
      ],
      "status": "Backlog"
    },
    {
      "issue_id": "WOF-003",
      "theme": "Daily Wage Divisor Precision and Leave Accrual Inconsistency",
      "cluster_id": "CLU-001",
      "limitation": "The payroll system uses a custom daily wage divisor (30.42 days) instead of calendar days, which can result in deduction amounts that don't precisely match the monthly salary and creates user confusion about calculation methods. Additionally, the 'working days' setting causes monthly fluctuations in leave salary accrual calculations, meaning the daily wage rate changes based on the number of working days in each month, leading to inconsistent cumulative totals.",
      "impact": "medium",
      "affected_personas": [
        "HR Admin",
        "Finance Manager",
        "Employee"
      ],
      "by_design": false,
      "design_rationale": null,
      "documented_workaround": null,
      "ticket_count": 2,
      "journey_stages": [
        "Day-to-day Usage",
        "Reporting"
      ],
      "categories": [
        "configuration_problem",
        "data_inconsistency"
      ],
      "jira_refs": [
        "TSSD-4368",
        "TSSD-3648"
      ],
      "status": "Won't Do"
    },
    {
      "issue_id": "WOF-004",
      "theme": "Time Off and Payroll Module Synchronization Gap",
      "cluster_id": "CLU-005",
      "limitation": "The Bayzat platform lacks real-time synchronization between Time Off and Payroll modules, preventing automatic recalculation when public holidays are added after leave requests or when leave request statuses change. The leave request tracking system lacks robust state management, causing inconsistent record persistence across multiple database tables and preventing reliable maintenance of a single source of truth for leave request statuses. This creates inconsistent daily wage calculations that cannot be retroactively corrected.",
      "impact": "high",
      "affected_personas": [
        "HR Admin",
        "Finance Manager"
      ],
      "by_design": false,
      "design_rationale": null,
      "documented_workaround": null,
      "ticket_count": 2,
      "journey_stages": [
        "Day-to-day Usage",
        "Troubleshooting"
      ],
      "categories": [
        "data_inconsistency",
        "integration_issue"
      ],
      "jira_refs": [
        "TSSD-2056",
        "TSSD-4464"
      ],
      "status": "Backlog"
    },
    {
      "issue_id": "WOF-005",
      "theme": "Working Days Configuration Clarity and Documentation",
      "cluster_id": "CLU-006",
      "limitation": "Users may experience confusion about how the working days configuration affects salary proration calculations. While the system correctly calculates based on configured working days, the lack of clear guidance on how work week configuration (including all 7 days as working days) impacts monthly calculations can lead to support inquiries and misunderstandings about system behavior.",
      "impact": "medium",
      "affected_personas": [
        "HR Admin",
        "Finance Manager"
      ],
      "by_design": true,
      "design_rationale": "System correctly calculates based on work week configuration; issue is documentation and user guidance clarity rather than system malfunction.",
      "documented_workaround": "Verify work week configuration in employee master to understand the number of working days configured for the month.",
      "ticket_count": 1,
      "journey_stages": [
        "Troubleshooting"
      ],
      "categories": [
        "ux_issue",
        "configuration_problem"
      ],
      "jira_refs": [
        "TSSD-4292"
      ],
      "status": "Won't Do"
    }
  ],
